# Copy this file to `.env` and fill in your values. The `.env` file is gitignored.

# Required: your Google AI Studio API key (https://aistudio.google.com/apikey).
GOOGLE_API_KEY=

# Optional: default output directory for saved research reports.
# Leave empty to save in the current working directory.
# Example: /Users/you/Obsidian/Research
OBSIDIAN_VAULT_PATH=
